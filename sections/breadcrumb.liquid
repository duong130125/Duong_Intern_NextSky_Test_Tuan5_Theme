{% render 'section-styles', section: section %}

<nav
  class="breadcrumb full-width section-{{ section.id }}-padding"
  aria-label="{{ 'sections.breadcrumb.label' | t }}"
>
  <div class="breadcrumb__inner section-inner section-inner--{{ section.settings.section_width }}">
    <ol class="breadcrumb__list">
      <li class="breadcrumb__item">
        <a href="{{ routes.root_url }}" class="breadcrumb__link">{{ 'sections.breadcrumb.home' | t }}</a>
      </li>
      {% if template.name == 'page' and page.title != blank %}
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span class="breadcrumb__current" aria-current="page">{{ page.title | escape }}</span>
        </li>
      {% elsif template.name == 'collection' and collection.title != blank %}
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span class="breadcrumb__current" aria-current="page">{{ collection.title | escape }}</span>
        </li>
      {% elsif template.name == 'product' and product.title != blank %}
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <a href="{{ routes.collections_url }}" class="breadcrumb__link">{{ 'collections.title' | t }}</a>
        </li>
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span class="breadcrumb__current" aria-current="page">{{ product.title | escape }}</span>
        </li>
      {% elsif template.name == 'blog' and blog.title != blank %}
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span class="breadcrumb__current" aria-current="page">{{ blog.title | escape }}</span>
        </li>
      {% elsif template.name == 'article' and article.title != blank %}
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <a href="{{ blog.url }}" class="breadcrumb__link">{{ blog.title | escape }}</a>
        </li>
        <li class="breadcrumb__item">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span class="breadcrumb__current" aria-current="page">{{ article.title | escape }}</span>
        </li>
      {% endif %}
    </ol>
  </div>
</nav>

{% stylesheet %}
  .breadcrumb {
    border-bottom: 1px solid rgba(18, 18, 18, 0.08);
    background: #fff;
  }

  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
  }

  .breadcrumb__link {
    color: rgba(18, 18, 18, 0.65);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb__link:hover {
    color: #121212;
  }

  .breadcrumb__separator {
    color: rgba(18, 18, 18, 0.35);
  }

  .breadcrumb__current {
    color: #121212;
    font-weight: 500;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.breadcrumb.name",
  "class": "breadcrumb-section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:labels.section_width",
      "options": [
        { "value": "default", "label": "t:options.section_width.default" },
        { "value": "fluid", "label": "t:options.section_width.fluid" },
        { "value": "stretch", "label": "t:options.section_width.stretch" },
        { "value": "full", "label": "t:options.section_width.full" }
      ],
      "default": "stretch"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_bottom",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "t:sections.breadcrumb.name"
    }
  ]
}
{% endschema %}
