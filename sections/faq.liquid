{% render 'section-styles', section: section %}

{%- style -%}
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: 40px !important;
      padding-bottom: 90px !important;
    }
    #section-header-{{ section.id }} .section-header__heading {
      font-size: 3.6rem !important;
    }
  }
{%- endstyle -%}

{% liquid
  assign contact_block = blank
  for block in section.blocks
    if block.type == 'contact'
      assign contact_block = block
      break
    endif
  endfor
%}

<div
  class="
    faq
    section-{{ section.id }}-padding
    {% if section.settings.section_width == 'full' or section.settings.section_width == 'stretch' %}full-width{% endif %}
  "
>
  <div
    class="
      faq__inner
      section-inner
      section-inner--{{ section.settings.section_width }}
      color-{{ section.settings.color_scheme }}
      gradient
      {% if section.settings.remove_section_spacing %}section-inner--no-spacing{% endif %}
    "
  >
    {% if section.settings.show_breadcrumb %}
      <nav class="faq__breadcrumb" aria-label="{{ 'sections.breadcrumb.label' | t }}">
        <a href="{{ routes.root_url }}" class="faq__breadcrumb-link">{{ 'sections.breadcrumb.home' | t }}</a>
        <span class="faq__breadcrumb-dot" aria-hidden="true">&middot;</span>
        <span class="faq__breadcrumb-current" aria-current="page">
          {% if page.title != blank %}
            {{ page.title | escape }}
          {% else %}
            {{ 'sections.faq.name' | t }}
          {% endif %}
        </span>
      </nav>
    {% endif %}

    {% render 'section-header', section: section %}

    <div class="faq__layout">
      {% if contact_block != blank %}
        <aside class="faq__sidebar">
          <div class="faq__contact" {{ contact_block.shopify_attributes }}>
            {% if contact_block.settings.heading != blank %}
              <h2 class="faq__contact-title">{{ contact_block.settings.heading | escape }}</h2>
            {% endif %}
            {% if contact_block.settings.description != blank %}
              <div class="faq__contact-description rte">{{ contact_block.settings.description }}</div>
            {% endif %}
            <div class="faq__contact-actions">
              {% if contact_block.settings.button_label != blank %}
                <a
                  href="{{ contact_block.settings.button_link | default: '#' }}"
                  class="faq__button faq__button--outline"
                >
                  {{ contact_block.settings.button_label | escape }}
                </a>
              {% endif %}
              {% if contact_block.settings.button_secondary_label != blank %}
                <a
                  href="{{ contact_block.settings.button_secondary_link | default: '#' }}"
                  class="faq__button faq__button--solid"
                >
                  {{ contact_block.settings.button_secondary_label | escape }}
                </a>
              {% endif %}
            </div>
          </div>
        </aside>
      {% endif %}

      <div class="faq__main">
        {% liquid
          assign in_category = false
        %}

        {% for block in section.blocks %}
          {% if block.type == 'contact' %}
            {% continue %}
          {% endif %}

          {% case block.type %}
            {% when 'category' %}
              {% if in_category %}
                </div>
                </div>
              {% endif %}
              <div class="faq__category" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="faq__category-title">{{ block.settings.heading | escape }}</h2>
                {% endif %}
                <div class="faq__items">
                  {% assign in_category = true %}
            {% when 'question' %}
              {% unless in_category %}
                <div class="faq__category">
                  <div class="faq__items">
                    {% assign in_category = true %}
              {% endunless %}

              <details class="faq__item" {{ block.shopify_attributes }}>
                <summary class="faq__question">
                  <span class="faq__question-text">{{ block.settings.question | escape }}</span>
                  <span class="faq__icon" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path class="faq__icon-vertical" d="M7 1V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      <path d="M1 7H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </span>
                </summary>
                {% if block.settings.answer != blank %}
                  <div class="faq__answer rte">
                    {{ block.settings.answer }}
                  </div>
                {% endif %}
              </details>
          {% endcase %}
        {% endfor %}

        {% if in_category %}
          </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .faq {
    width: 100%;
  }

  .faq__inner {
    width: 100%;
  }

  .faq__breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    margin-bottom: 0.8rem;
    font-size: 1.4rem;
    line-height: 1.7;
  }

  .faq__breadcrumb-link {
    color: rgba(17, 17, 17, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq__breadcrumb-link:hover {
    color: #121212;
  }

  .faq__breadcrumb-dot {
    color: rgb(203, 203, 203);
  }

  .faq__breadcrumb-current {
    color: #111111;
    font-weight: 500;
  }

  .faq__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    margin-top: 6rem;
    align-items: start;
    width: 100%;
    max-width: 100%;
    margin-inline: auto;
  }

  .faq__sidebar {
    width: 100%;
  }

  .faq__contact {
    padding: 4rem;
    border-radius: 1.2rem;
    background: #f5f5f5;
    text-align: left;
    width: 42rem;
    min-height: 39.898rem;
    box-sizing: border-box;
  }

  .faq__contact-title {
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.21;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  .faq__contact-description {
    font-size: 1.4rem;
    line-height: 1.71;
    color: rgb(68, 68, 68);
  }

  .faq__contact-description p {
    margin: 0 0 1rem;
  }

  .faq__contact-description p:last-child {
    margin-bottom: 0;
  }

  .faq__contact-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .faq__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 4.8rem;
    padding: 1.3rem 5.5rem;
    border-radius: 30px;
    font-size: 1.5rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .faq__button:hover {
    opacity: 0.88;
  }

  .faq__button--outline {
    background: #ffffff;
    color: #121212;
    border: 1px solid #121212;
  }

  .faq__button--solid {
    background: #121212;
    color: #ffffff;
    border: 1px solid #121212;
  }

  .faq__main {
    min-width: 0;
  }

  .faq__category + .faq__category {
    margin-top: 3.6rem;
  }

  .faq__category-title {
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.21;
    margin-bottom: 1.6rem;
    letter-spacing: -0.02em;
    text-align: left;
  }

  .faq__items {
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    border: 0;
    border-bottom: 1.5px solid rgba(18, 18, 18, 0.08);
    transition: border-color 0.2s ease;
  }

  .faq__item:hover,
  .faq__item[open] {
    border-bottom-color: #121212;
    position: relative;
    z-index: 1;
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding: 2rem 0;
    cursor: pointer;
    list-style: none;
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.5;
    background: transparent;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question-text {
    flex: 1;
    padding-right: 1rem;
  }

  .faq__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    transition: transform 0.25s ease;
  }

  .faq__item[open] .faq__icon {
    transform: rotate(45deg);
  }

  .faq__answer {
    padding: 0 0 2rem;
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgb(68, 68, 68);
    background: transparent;
  }

  .faq__answer > :first-child {
    margin-top: 0;
  }

  .faq__answer > :last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 990px) {
    .faq {
      grid-column: 1 / -1;
    }

    .faq__inner {
      max-width: 123rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-inline: auto;
      box-sizing: border-box;
    }

    .faq__layout {
      grid-template-columns: 42rem 73rem;
      gap: 5rem;
    }

    .faq__sidebar {
      position: sticky;
      top: 10rem;
    }

    .faq__main {
      width: 73rem;
      min-height: 124.855rem;
    }

    .faq__category + .faq__category {
      margin-top: 5rem;
    }

    .faq__contact-title {
      font-size: 2.4rem;
    }

    .faq__category-title {
      font-size: 2.4rem;
      margin-bottom: 1rem;
    }

    .faq__question {
      font-size: 1.6rem;
      padding: 1.77rem 0;
    }

    .faq__answer {
      font-size: 1.5rem;
      padding: 0 0 2.4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "tag": "section",
  "class": "faq-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.layout.header"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:labels.section_width",
      "options": [
        { "value": "default", "label": "t:options.section_width.default" },
        { "value": "fluid", "label": "t:options.section_width.fluid" },
        { "value": "stretch", "label": "t:options.section_width.stretch" },
        { "value": "full", "label": "t:options.section_width.full" }
      ],
      "default": "default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.faq.settings.show_breadcrumb.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Help Center"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Please use the below form. You can also call customer service on +1(973) 435-3638.</p>"
    },
    {
      "type": "select",
      "id": "header_size",
      "label": "t:labels.header_size",
      "options": [
        { "value": "small", "label": "t:options.size.small" },
        { "value": "medium", "label": "t:options.size.medium" },
        { "value": "large", "label": "t:options.size.large" }
      ],
      "default": "medium"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:labels.alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 40
