{% render 'section-styles', section: section %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --faq-gutter-x: 1.5rem;
    --faq-page-width: 120rem;
  }
{%- endstyle -%}

{% liquid
  assign contact_block = blank
  for block in section.blocks
    if block.type == 'contact'
      assign contact_block = block
      break
    endif
  endfor
%}

<div
  class="
    faq
    full-width
    section-{{ section.id }}-padding
  "
>
  <div
    class="
      faq__inner
      section-inner
      section-inner--{{ section.settings.section_width }}
      color-{{ section.settings.color_scheme }}
      gradient
      {% if section.settings.remove_section_spacing %}section-inner--no-spacing{% endif %}
    "
  >
    {% if section.settings.show_breadcrumb %}
      <nav class="faq__breadcrumb" aria-label="{{ 'sections.breadcrumb.label' | t }}">
        <a href="{{ routes.root_url }}" class="faq__breadcrumb-link">{{ 'sections.breadcrumb.home' | t }}</a>
        <span class="faq__breadcrumb-dot" aria-hidden="true">&middot;</span>
        <span class="faq__breadcrumb-current" aria-current="page">
          {% if page.title != blank %}
            {{ page.title | escape }}
          {% else %}
            {{ 'sections.faq.name' | t }}
          {% endif %}
        </span>
      </nav>
    {% endif %}

    {% render 'section-header', section: section %}

    <div class="faq__layout{% if contact_block == blank %} faq__layout--full-width{% endif %}">
      {% if contact_block != blank %}
        <aside class="faq__sidebar">
          <div class="faq__contact" {{ contact_block.shopify_attributes }}>
            {% if contact_block.settings.heading != blank %}
              <h2 class="faq__contact-title">{{ contact_block.settings.heading | escape }}</h2>
            {% endif %}
            {% if contact_block.settings.description != blank %}
              <div class="faq__contact-description rte">{{ contact_block.settings.description }}</div>
            {% endif %}
            <div class="faq__contact-actions">
              {% if contact_block.settings.button_label != blank %}
                <a
                  href="{{ contact_block.settings.button_link | default: '#' }}"
                  class="faq__button faq__button--outline"
                >
                  {{ contact_block.settings.button_label | escape }}
                </a>
              {% endif %}
              {% if contact_block.settings.button_secondary_label != blank %}
                <a
                  href="{{ contact_block.settings.button_secondary_link | default: '#' }}"
                  class="faq__button faq__button--solid"
                >
                  {{ contact_block.settings.button_secondary_label | escape }}
                </a>
              {% endif %}
            </div>
          </div>
        </aside>
      {% endif %}

      <div class="faq__main">
        {%- liquid
          assign category_open = false
        -%}
        {% for block in section.blocks %}
          {% if block.type == 'contact' %}
            {% continue %}
          {% endif %}

          {% if block.type == 'category' %}
            {% if category_open %}
              </div>
              </div>
            {% endif %}
              <div class="faq__category" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h2 class="faq__category-title">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              <div class="faq__items">
            {% liquid
              assign category_open = true
            %}

          {% elsif block.type == 'question' %}
            {% unless category_open %}
              <div class="faq__category">
                <div class="faq__items">
              {% liquid
                assign category_open = true
              %}
            {% endunless %}
            <details class="faq__item" {{ block.shopify_attributes }}>
              <summary class="faq__question">
                <span class="faq__question-text">{{ block.settings.question | escape }}</span>
                <span class="faq__icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path class="faq__icon-vertical" d="M7 1V13" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                    <path class="faq__icon-horizontal" d="M1 7H13" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              {% if block.settings.answer != blank %}
                <div class="faq__answer rte">
                  {{ block.settings.answer }}
                </div>
              {% endif %}
            </details>
          {% endif %}
        {% endfor %}
        {% if category_open %}
          </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .faq {
    width: 100%;
  }

  /* Container: giống .container demo Glozin */
  .faq__inner {
    --faq-gutter-x: 1.5rem;
    width: 100%;
    max-width: 100%;
    margin-inline: auto;
    padding-inline: var(--faq-gutter-x);
    box-sizing: border-box;
  }

  .faq__inner.section-inner--default,
  .faq__inner.section-inner--fluid,
  .faq__inner.section-inner--full {
    max-width: 100%;
  }

  .faq__breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    margin-bottom: 0.8rem;
    font-size: 1.4rem;
    line-height: 1.7;
  }

  .faq__breadcrumb-link {
    color: rgba(17, 17, 17, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq__breadcrumb-link:hover {
    color: #121212;
  }

  .faq__breadcrumb-dot {
    color: rgb(203, 203, 203);
  }

  .faq__breadcrumb-current {
    color: #111111;
    font-weight: 500;
  }

  .faq .section-header {
    margin-bottom: 0;
  }

  .faq__layout {
    --faq-layout-gap: 5rem;
    --faq-layout-margin-top: clamp(4rem, 4.5vw, 6rem);
    --faq-sidebar-width: 100%;
    --faq-contact-padding-block: clamp((40 * .64px), calc((40 * .64px) + (40 - (40 * .64)) * ((100vw - 575px) / (1600 - 575))), calc(40 * 1px));
    --faq-contact-padding-inline: clamp(1.5rem, calc(1.5rem + (40 - 15) * ((100vw - 57.5rem) / (1600 - 575))), 40px);
    --faq-contact-title-size: 2.4rem;
    --faq-contact-title-spacing: 2rem;
    --faq-category-title-size: 2.4rem;
    --faq-category-title-spacing: 1rem;
    --faq-category-spacing: clamp(3.2rem, calc(3.2rem + (5 - 3.2) * ((100vw - 57.5rem) / (120 - 37.5))), 5rem);
    --faq-question-size: 1.6rem;
    --faq-question-padding: 1.765rem 0;
    --faq-answer-size: 1.4rem;
    --faq-answer-padding: 0 0 2rem;
    --faq-button-size: 1.5rem;
    --faq-button-padding: 1.3rem 2rem;
    --faq-button-height: 4.8rem;
    --faq-button-gap: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--faq-layout-gap);
    margin-top: var(--faq-layout-margin-top);
    align-items: start;
    width: 100%;
  }

  .faq__sidebar {
    width: var(--faq-sidebar-width);
    min-width: 0;
  }

  .faq__contact {
    padding-block: var(--faq-contact-padding-block);
    padding-inline: var(--faq-contact-padding-inline);
    border-radius: 1.2rem;
    background: #f5f5f5;
    text-align: left;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .faq__contact-title {
    font-size: var(--faq-contact-title-size);
    color: #111111;
    font-weight: 600;
    line-height: 1.21;
    margin: 0 0 var(--faq-contact-title-spacing);
    letter-spacing: -0.02em;
  }

  .faq__contact-description {
    font-size: 1.4rem;
    line-height: 1.71;
    color: rgb(68, 68, 68);
  }

  .faq__contact-description p {
    margin: 0 0 1rem;
  }

  .faq__contact-description p:last-child {
    margin-bottom: 1.5rem;
  }

  .faq__contact-actions {
    display: flex;
    flex-direction: column;
    gap: var(--faq-button-gap);
    margin-bottom: 1rem;
  }

  .faq__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: var(--faq-button-height);
    padding: var(--faq-button-padding);
    border-radius: 30px;
    font-size: var(--faq-button-size);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .faq__button:hover {
    opacity: 0.88;
  }

  .faq__button--outline {
    background: #ffffff;
    color: #111111;
    border: 1px solid #111111;
  }

  .faq__button--solid {
    background: #121212;
    color: #ffffff;
    border: 1px solid #121212;
  }

  .faq__main {
    min-width: 0;
    width: 100%;
  }

  .faq__category + .faq__category {
    margin-top: var(--faq-category-spacing);
  }

  .faq__category-title {
    font-size: var(--faq-category-title-size);
    font-weight: 600;
    color: #111111 !important;
    line-height: 1.21;
    margin: 0 0 var(--faq-category-title-spacing);
    letter-spacing: -0.02em;
    text-align: left;
  }

  .faq__items {
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    border: 0;
    border-bottom: 1.5px solid rgba(18, 18, 18, 0.08);
    transition: border-color 0.2s ease;
  }

  .faq__item:hover,
  .faq__item[open] {
    border-bottom-color: #121212;
    position: relative;
    z-index: 1;
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--faq-question-padding);
    cursor: pointer;
    list-style: none;
    font-size: var(--faq-question-size);
    font-weight: 500;
    line-height: 1.5;
    background: transparent;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question-text {
    flex: 1;
    color: #111111 !important;
    font-weight: 600;
    font-size: var(--faq-question-size);
  }

  .faq__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    transition: transform 0.25s ease;
  }

  .faq__icon svg {
    overflow: visible;
  }

  .faq__icon-vertical {
    transition: transform 0.25s ease;
    transform-origin: 7px 7px;
  }

  .faq__icon-horizontal {
    transition: transform 0.25s ease;
    transform-origin: 7px 7px;
  }

  .faq__item[open] .faq__icon-vertical {
    transform: rotate(90deg);
  }

  .faq__item[open] .faq__icon-horizontal {
    transform: rotate(180deg);
  }

  .faq__answer {
    padding: var(--faq-answer-padding);
    font-size: var(--faq-answer-size);
    font-weight: 400;
    line-height: 1.7;
    color: rgb(68, 68, 68);
    background: transparent;
  }

  .faq__answer > :first-child {
    margin-top: 0;
  }

  .faq__answer > :last-child {
    margin-bottom: 0;
  }

  /* Mobile → 1024px */
  @media screen and (max-width: 1024px) {
    .section-header--large .section-header__heading {
      font-size: 3rem;
      line-height: 1.1;
    }

    .faq .section-header__description {
      margin-top: 1rem;
    }
  }

  /* Tablet+ : 2 cột 35% / 65%, gap 50px như demo */
  @media screen and (min-width: 768px) {
    .faq__layout:not(.faq__layout--full-width) {
      grid-template-columns: minmax(0, 35%) minmax(0, 1fr);
      --faq-layout-gap: 5rem;
    }
  }

  /* Desktop small: container width 90% */
  @media screen and (min-width: 1025px) {
    .faq__inner.section-inner--default,
    .faq__inner.section-inner--fluid {
      width: 90%;
    }

    .faq__layout:not(.faq__layout--full-width) {
      --faq-layout-margin-top: 6rem;
    }

    .faq__layout--full-width {
      grid-template-columns: 1fr;
    }

    .faq__sidebar {
      position: sticky;
      top: 3rem;
    }
  }

  /* Desktop: max-width container 1200px + gutter (giữ width 90% như demo) */
  @media screen and (min-width: 1200px) {
    .faq__inner.section-inner--default,
    .faq__inner.section-inner--fluid {
      max-width: calc(var(--faq-page-width, var(--page-width)) + var(--faq-gutter-x) * 2);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "tag": "section",
  "class": "faq-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.layout.header"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:labels.section_width",
      "options": [
        { "value": "default", "label": "t:options.section_width.default" },
        { "value": "fluid", "label": "t:options.section_width.fluid" },
        { "value": "stretch", "label": "t:options.section_width.stretch" },
        { "value": "full", "label": "t:options.section_width.full" }
      ],
      "default": "default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.faq.settings.show_breadcrumb.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
