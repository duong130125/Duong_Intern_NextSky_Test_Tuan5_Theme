    {
      "type": "checkbox",
      "id": "remove_section_spacing",
      "label": "t:labels.remove_section_spacing",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "contact",
      "name": "t:sections.faq.blocks.contact.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Contact Us"
        },
        {
          "type": "richtext",
          "id": "description",
