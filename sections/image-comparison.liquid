{% render 'section-styles', section: section %}

{% liquid
  assign image_ratio = section.settings.image_ratio
  assign custom_ratio = section.settings.custom_ratio | default: '1/1'
  assign content_width = section.settings.content_width
  assign content_position = section.settings.content_position
  assign show_before_after_text = section.settings.show_before_after_text
  assign before_image = section.settings.before_image
  assign after_image = section.settings.after_image
%}

{%- style -%}
  .image-comparison--{{ section.id }} .image-comparison__inner {
    max-width: 100%;
    margin-inline: auto;
  }

  {% if image_ratio == 'custom' %}
    .image-comparison--{{ section.id }} .image-comparison__slider {
      aspect-ratio: {{ custom_ratio }};
    }
  {% endif %}

  @media screen and (min-width: 1200px) {
    .image-comparison--{{ section.id }} .image-comparison__inner {
      max-width: calc(100% - 60px);
      width: calc(100% - 60px);
    }
    .image-comparison--{{ section.id }} .image-comparison__slider {
      border-radius: 2rem;
    }
  }

  @media screen and (min-width: 1920px) {
    .image-comparison--{{ section.id }} .image-comparison__inner {
      max-width: 1860px;
      width: 1860px;
    }
  }
{%- endstyle -%}

<div
  class="
    image-comparison
    image-comparison--{{ section.id }}
    section-{{ section.id }}-padding
    {% if section.settings.section_width == 'full' or section.settings.section_width == 'stretch' %}full-width{% endif %}
  "
>
  <div
    class="
      image-comparison__inner
      section-inner
      section-inner--{{ section.settings.section_width }}
      color-{{ section.settings.color_scheme }}
      gradient
      {% if section.settings.remove_section_spacing %}section-inner--no-spacing{% endif %}
    "
  >
    {% render 'section-header', section: section %}

    <div
      class="
        image-comparison__content
        image-comparison__content--{{ content_width }}
        image-comparison__content--{{ content_position }}
      "
    >
      <div
        class="
          image-comparison__slider
          image-comparison__slider--{{ image_ratio }}
        "
        data-image-comparison
      >
        {%- comment -%} After image (full background) {%- endcomment -%}
        <div class="image-comparison__after">
          {% if after_image != blank %}
            {{
              after_image
              | image_url: width: 1920
              | image_tag: class: 'image-comparison__image', loading: 'lazy', widths: '375, 550, 750, 1100, 1500, 1920'
            }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'image-comparison__placeholder' }}
          {% endif %}
          {% if show_before_after_text %}
            <span class="image-comparison__label image-comparison__label--after">
              {{ 'sections.image_comparison.after_text' | t }}
            </span>
          {% endif %}
        </div>

        {%- comment -%} Before image (clipped) {%- endcomment -%}
        <div class="image-comparison__before" data-before-clip>
          {% if before_image != blank %}
            {{
              before_image
              | image_url: width: 1920
              | image_tag: class: 'image-comparison__image', loading: 'lazy', widths: '375, 550, 750, 1100, 1500, 1920'
            }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'image-comparison__placeholder' }}
          {% endif %}
          {% if show_before_after_text %}
            <span class="image-comparison__label image-comparison__label--before">
              {{ 'sections.image_comparison.before_text' | t }}
            </span>
          {% endif %}
        </div>

        {%- comment -%} Slider handle {%- endcomment -%}
        <div class="image-comparison__handle" data-handle>
          <div class="image-comparison__handle-line"></div>
          <button
            class="image-comparison__handle-button"
            type="button"
            aria-label="{{ 'sections.image_comparison.slider_label' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="20" viewBox="0 0 8 20" fill="none">
              <path d="M0.25 0.25V19.75H1.75V0.25H0.25ZM6.25 0.25V19.75H7.75V0.25H6.25Z" fill="#000000"></path>
            </svg>
          </button>
          <div class="image-comparison__handle-line"></div>
        </div>

        {%- comment -%} Before/After labels {%- endcomment -%}
        {%- comment -%} labels moved inside image containers so they are clipped by the slider naturally {%- endcomment -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .image-comparison {
    width: 100%;
  }

  .image-comparison__inner {
    width: 100%;
  }

  .image-comparison__content {
    margin-top: 0;
  }

  .image-comparison .section-header + .image-comparison__content {
    margin-top: 3.2rem;
  }

  .image-comparison__content--50 {
    max-width: 50%;
  }
  .image-comparison__content--66 {
    max-width: 66.666%;
  }
  .image-comparison__content--75 {
    max-width: 75%;
  }
  .image-comparison__content--100 {
    max-width: 100%;
  }

  .image-comparison__content--left {
    margin-left: 0;
    margin-right: auto;
  }
  .image-comparison__content--right {
    margin-left: auto;
    margin-right: 0;
  }

  .image-comparison__slider {
    position: relative;
    overflow: hidden;
    border-radius: 0.8rem;
    cursor: col-resize;
    user-select: none;
    -webkit-user-select: none;
  }

  @media screen and (max-width: 1199px) {
    .full-width .image-comparison__slider {
      border-radius: 0;
    }
  }

  /* Image ratio classes */
  .image-comparison__slider--adapt {
    aspect-ratio: auto;
  }
  .image-comparison__slider--square {
    aspect-ratio: 1 / 1;
  }
  .image-comparison__slider--portrait {
    aspect-ratio: 3 / 4;
  }
  .image-comparison__slider--landscape {
    aspect-ratio: 4 / 3;
  }

  .image-comparison__after,
  .image-comparison__before {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .image-comparison__slider--adapt .image-comparison__after {
    position: relative;
    height: auto;
  }

  .image-comparison__slider--adapt .image-comparison__before {
    position: absolute;
    height: 100%;
  }

  .image-comparison__before {
    z-index: 2;
    clip-path: inset(0 50% 0 0);
  }

  .image-comparison__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-comparison__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #e0e0e0;
  }

  .image-comparison__placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Handle */
  .image-comparison__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transform: translateX(-50%);
    pointer-events: auto;
  }

  .image-comparison__handle-line {
    width: 2px;
    flex: 1;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 4px rgba(0, 0, 0, 0.15);
  }

  .image-comparison__handle-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 8rem;
    border-radius: 60px;
    border: none;
    background: #ffffff;
    color: #000000;
    cursor: grab;
    pointer-events: auto;
    touch-action: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    flex-shrink: 0;
    z-index: 7;
  }

  .image-comparison__handle-button:active {
    transform: none;
  }

  .image-comparison__handle-button svg {
    pointer-events: none;
  }

  /* Labels placed inside each image so they get clipped/covered naturally */
  .image-comparison__label {
    position: absolute;
    bottom: 3rem;
    font-size: 1.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #000000;
    line-height: 1.25;
    max-width: 12rem;
    pointer-events: none;
  }

  .image-comparison__after .image-comparison__label--after {
    right: 5rem;
    text-align: right;
    z-index: 1; /* underneath the before layer so it gets covered */
  }

  .image-comparison__before .image-comparison__label--before {
    left: 5rem;
    text-align: left;
    z-index: 3;
  }

  /* Mobile */
  @media screen and (max-width: 767px) {
    .image-comparison__content--50,
    .image-comparison__content--66,
    .image-comparison__content--75 {
      max-width: 100%;
    }

    .image-comparison__content--left,
    .image-comparison__content--right {
      margin-left: auto;
      margin-right: auto;
    }

    .image-comparison__handle-button {
      width: 4.5rem;
      height: 8rem;
    }
  }

  /* Desktop small */
  @media screen and (min-width: 1025px) {
    .image-comparison .section-header + .image-comparison__content {
      margin-top: 4rem;
    }

    .image-comparison__label {
      font-size: 1.8rem;
      max-width: 18rem;
    }

    .image-comparison__labels {
      padding: 4rem 4.8rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function initSlider(container) {
      const beforeEl = container.querySelector('[data-before-clip]');
      const handleEl = container.querySelector('[data-handle]');
      if (!beforeEl || !handleEl) return;

      let isDragging = false;
      let rect;

      function updatePosition(x) {
        if (x === undefined) return;
        rect = container.getBoundingClientRect();

        const btn = handleEl.querySelector('button');
        const btnHalf = btn ? btn.offsetWidth / 2 : 0;

        // clamp the clientX so the center of the button never goes beyond
        // rect.left + btnHalf .. rect.right - btnHalf
        const minX = rect.left + btnHalf;
        const maxX = rect.left + rect.width - btnHalf;

        let clampedX = Math.max(minX, Math.min(maxX, x));

        let pos = (clampedX - rect.left) / rect.width;
        pos = Math.max(0, Math.min(1, pos));
        const percent = pos * 100;

        beforeEl.style.clipPath = 'inset(0 ' + (100 - percent) + '% 0 0)';
        handleEl.style.left = percent + '%';
      }

      function addDragListeners() {
        document.addEventListener('mousemove', onPointerMove);
        document.addEventListener('touchmove', onPointerMove, { passive: false });
        document.addEventListener('mouseup', onPointerUp);
        document.addEventListener('touchend', onPointerUp);
      }

      function removeDragListeners() {
        document.removeEventListener('mousemove', onPointerMove);
        document.removeEventListener('touchmove', onPointerMove, { passive: false });
        document.removeEventListener('mouseup', onPointerUp);
        document.removeEventListener('touchend', onPointerUp);
      }

      function preventDragStart(e) {
        e.preventDefault();
      }

      function onPointerDown(e) {
        isDragging = true;
        rect = container.getBoundingClientRect();
        container.style.cursor = 'col-resize';
        if (e.type === 'touchstart') {
          e.preventDefault();
        }
        const clientX =
          e.clientX !== undefined ? e.clientX : e.touches && e.touches[0] ? e.touches[0].clientX : undefined;
        updatePosition(clientX);
        addDragListeners();
      }

      function onPointerMove(e) {
        if (!isDragging) return;
        const clientX =
          e.clientX !== undefined ? e.clientX : e.touches && e.touches[0] ? e.touches[0].clientX : undefined;
        updatePosition(clientX);
      }

      function onPointerUp() {
        if (!isDragging) return;
        isDragging = false;
        container.style.cursor = 'col-resize';
        removeDragListeners();
      }

      container.addEventListener('mousedown', onPointerDown);
      container.addEventListener('touchstart', onPointerDown, { passive: false });
      container.addEventListener('dragstart', preventDragStart);

      /* Keyboard support for the handle button */
      const btn = handleEl.querySelector('button');
      if (btn) {
        btn.addEventListener('keydown', function (e) {
          rect = container.getBoundingClientRect();
          const currentLeft = parseFloat(handleEl.style.left) || 50;
          let newPos = currentLeft;
          if (e.key === 'ArrowLeft') {
            newPos = Math.max(0, currentLeft - 2);
          } else if (e.key === 'ArrowRight') {
            newPos = Math.min(100, currentLeft + 2);
          } else {
            return;
          }
          beforeEl.style.clipPath = 'inset(0 ' + (100 - newPos) + '% 0 0)';
          handleEl.style.left = newPos + '%';
          e.preventDefault();
        });
      }
    }

    /* Initialize all sliders */
    document.querySelectorAll('[data-image-comparison]').forEach(initSlider);

    /* Re-initialize on Shopify editor section events */
    if (typeof Shopify !== 'undefined' && Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (e) {
        e.target.querySelectorAll('[data-image-comparison]').forEach(initSlider);
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.image_comparison.name",
  "tag": "section",
  "class": "image-comparison-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.layout.header"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:labels.section_width",
      "options": [
        { "value": "default", "label": "t:options.section_width.default" },
        { "value": "fluid", "label": "t:options.section_width.fluid" },
        { "value": "stretch", "label": "t:options.section_width.stretch" },
        { "value": "full", "label": "t:options.section_width.full" }
      ],
      "default": "default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Before & After"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>See the amazing transformation with our products.</p>"
    },
    {
      "type": "select",
      "id": "header_size",
      "label": "t:labels.header_size",
      "options": [
        { "value": "small", "label": "t:options.size.small" },
        { "value": "medium", "label": "t:options.size.medium" },
        { "value": "large", "label": "t:options.size.large" }
      ],
      "default": "medium"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:labels.alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.image_comparison.settings.images_header"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "t:sections.image_comparison.settings.before_image.label"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "t:sections.image_comparison.settings.after_image.label"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:sections.image_comparison.settings.content_width.label",
      "options": [
        { "value": "50", "label": "50%" },
        { "value": "66", "label": "66%" },
        { "value": "75", "label": "75%" },
        { "value": "100", "label": "100%" }
      ],
      "default": "100"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:sections.image_comparison.settings.content_position.label",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_before_after_text",
      "label": "t:sections.image_comparison.settings.show_before_after_text.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.image_comparison.settings.image_ratio_header"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.image_comparison.settings.image_ratio.label",
      "options": [
        { "value": "adapt", "label": "t:sections.image_comparison.settings.image_ratio.options.adapt" },
        { "value": "square", "label": "t:sections.image_comparison.settings.image_ratio.options.square" },
        { "value": "portrait", "label": "t:sections.image_comparison.settings.image_ratio.options.portrait" },
        { "value": "landscape", "label": "t:sections.image_comparison.settings.image_ratio.options.landscape" },
        { "value": "custom", "label": "t:sections.image_comparison.settings.image_ratio.options.custom" }
      ],
      "default": "adapt"
    },
    {
      "type": "text",
      "id": "custom_ratio",
      "label": "t:sections.image_comparison.settings.custom_ratio.label",
      "info": "t:sections.image_comparison.settings.custom_ratio.info",
      "default": "16/9"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_bottom",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "remove_section_spacing",
      "label": "t:labels.remove_section_spacing",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_comparison.name",
      "settings": {
        "heading": "Before & After",
        "description": "<p>See the amazing transformation with our products.</p>",
        "show_before_after_text": true,
        "content_width": "100",
        "image_ratio": "adapt"
      }
    }
  ]
}
{% endschema %}
