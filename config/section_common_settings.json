  },
  {
    "type": "header",
    "content": "t:sections.all.header.content"
  },
  {
    "type": "text",
    "id": "heading",
    "label": "t:labels.heading",
    "default": ""
  },
  {
    "type": "richtext",
    "id": "description",
    "label": "t:labels.description"
  },
  {
