<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    <link rel="stylesheet" href="{{ 'non-critical.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript>
      <link rel="stylesheet" href="{{ 'non-critical.css' | asset_url }}">
    </noscript>

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    {{ content_for_layout }}
  </body>
</html>
